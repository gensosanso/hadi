---
import type { Tables } from '../types/supabase';

interface Props {
  clinic: Tables<'clinics_enriched'>;
}

const { clinic } = Astro.props;

// Helper to format specialties (remove 'point_of_interest', etc.)
const formatSpecialties = (types: string[] | null) => {
  if (!types) return [];
  const exclude = ['point_of_interest', 'establishment', 'health'];
  return types
    .filter(t => !exclude.includes(t))
    .map(t => t.replace(/_/g, ' ').charAt(0).toUpperCase() + t.slice(1).replace(/_/g, ' '));
};

const specialties = formatSpecialties(clinic.specialites);
---

<div 
  class={`clinic-card rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col h-full group relative border-2 ${
    clinic.plan === 'sponsor' ? 'bg-indigo-50/30 border-indigo-200' : 
    clinic.plan === 'premium' ? 'bg-blue-50/20 border-blue-100' : 
    'bg-white border-gray-50'
  }`}
  data-search={`${clinic.nom} ${specialties.join(' ')} ${clinic.quartier || ''}`.toLowerCase()}
>
  {clinic.plan === 'sponsor' && (
    <span class="absolute -top-3 left-4 bg-indigo-600 text-white text-[10px] px-3 py-1 rounded-full font-bold uppercase tracking-widest shadow-lg z-10">
      🚀 Sponsorisé
    </span>
  )}
  {clinic.plan === 'premium' && (
    <span class="absolute -top-3 left-4 bg-blue-500 text-white text-[10px] px-3 py-1 rounded-full font-bold uppercase tracking-widest shadow-md z-10">
      ✨ Premium
    </span>
  )}

  <div class="flex-grow">
    <div class="flex items-start justify-between mb-3">
      <h3 class={`text-xl font-bold transition tracking-tight ${
        clinic.plan === 'sponsor' ? 'text-indigo-900 group-hover:text-indigo-600' : 'group-hover:text-blue-600'
      }`}>
        {clinic.nom}
      </h3>
      <div class="flex flex-col items-end">
        {clinic.verified && (
          <span class="bg-blue-100 text-blue-800 text-[10px] px-2 py-0.5 rounded-full font-bold uppercase mb-1">
            Vérifié
          </span>
        )}
        {clinic.rating && (
          <div class="flex items-center gap-1 text-sm font-bold text-amber-500">
            <span>⭐</span>
            <span>{clinic.rating}</span>
            <span class="text-gray-300 font-normal text-xs">({clinic.user_rating_count})</span>
          </div>
        )}
      </div>
    </div>
    
    <div class="flex flex-wrap gap-2 mb-4">
      {specialties.length > 0 ? (
        specialties.map(spec => (
          <span class="bg-blue-50 text-blue-700 text-xs px-2 py-1 rounded-md">
            {spec}
          </span>
        ))
      ) : (
        <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md">
          Clinique Générale
        </span>
      )}
    </div>

    <p class="text-gray-600 text-sm line-clamp-3 mb-4 italic">
      {clinic.description_custom || "Informations détaillées sur cet établissement bientôt disponibles."}
    </p>
  </div>

  <div class="pt-4 border-t border-gray-100 mt-auto">
    <a 
      href={`/clinique/${clinic.slug}`} 
      class="block w-full text-center py-2 bg-gray-50 text-blue-600 rounded-lg font-semibold hover:bg-blue-600 hover:text-white transition-colors"
    >
      Voir les détails
    </a>
  </div>
</div>
